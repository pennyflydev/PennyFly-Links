# FlyLink environment template.
# Copy to .env.local (gitignored) and fill in. See docs/ENVIRONMENT.md for what
# each is for and how to obtain it. Empty optional vars leave that feature inert.

# ─── Clerk (auth) ── required ────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=              # Clerk → Webhooks → Signing Secret
ADMIN_CLERK_USER_ID=              # your Clerk user id → label admin

# ─── Supabase (database) ── required ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe billing (SaaS plans) ── inert until set ──────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_LABEL_MONTHLY_PRICE_ID=
STRIPE_LABEL_YEARLY_PRICE_ID=

# ─── Stripe Connect (artist payouts) ─────────────────────────────────────────
STRIPE_PLATFORM_FEE_BPS=250        # 250 = 2.5% platform fee

# ─── Spotify (pre-save + insights) ───────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=              # {PROD_URL}/api/auth/spotify/callback
NEXT_PUBLIC_SPOTIFY_REDIRECT_URI=

# ─── Cron ────────────────────────────────────────────────────────────────────
CRON_SECRET=                      # protects /api/cron/fulfill-presaves

# ─── Twilio (SMS drop alerts) ── inert until set ─────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=                      # +1... number OR MG... Messaging Service SID

# ─── Google Wallet (passes + tickets) ── inert until set ─────────────────────
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_CLASS_ID=
GOOGLE_WALLET_SA_EMAIL=
GOOGLE_WALLET_SA_PRIVATE_KEY=

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=                    # mailto:you@example.com

# ─── Bandsintown (tour import) ── optional ───────────────────────────────────
BANDSINTOWN_APP_ID=flylink

# ─── Resend (transactional email — ticket delivery) ── inert until set ───────
RESEND_API_KEY=
EMAIL_FROM=                       # e.g. "FlyLink <tickets@yourdomain.com>"

# ─── Email integrations (NOT wired in code yet) ──────────────────────────────
AWEBER_CLIENT_ID=
AWEBER_CLIENT_SECRET=
NEXT_PUBLIC_AWEBER_REDIRECT_URI=
MAILCHIMP_CLIENT_ID=
MAILCHIMP_CLIENT_SECRET=
NEXT_PUBLIC_MAILCHIMP_REDIRECT_URI=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PROD_URL=             # production URL (used for redirects/origins)
NEXT_PUBLIC_APP_NAME=FlyLink
